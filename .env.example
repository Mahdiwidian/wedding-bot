# WhatsApp Session
SESSION_ID=wedding-bot-session

# ====================
# SUPABASE DATABASE
# ====================
# Get this from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# AI Provider
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Alternative AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Custom API (OpenAI-compatible / Anthropic-compatible)
# Set AI_PROVIDER=custom to use this
CUSTOM_API_BASE_URL=https://test.com
CUSTOM_API_TOKEN=test123
CUSTOM_API_MODEL=common

# Server
PORT=3000
BASE_URL=https://your-domain.com

# Storage (fallback if no DB)
DATA_DIR=./data
TEMPLATES_DIR=./templates
